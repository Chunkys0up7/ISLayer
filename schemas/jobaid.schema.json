{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mda-intent-engine.dev/schemas/jobaid.schema.json",
  "title": "MDA Intent Layer Job Aid",
  "description": "Schema for job aid condition/action lookup tables (.jobaid.yaml)",
  "type": "object",
  "required": ["jobaid_id", "capsule_id", "title", "version", "status", "dimensions", "rules"],
  "additionalProperties": false,
  "properties": {
    "jobaid_id": {
      "type": "string",
      "pattern": "^JA-[A-Z0-9]{2,3}-[A-Z0-9]{3}-\\d{3}$"
    },
    "capsule_id": {
      "type": "string",
      "pattern": "^CAP-[A-Z0-9]{2,3}-[A-Z0-9]{3}-\\d{3}$"
    },
    "title": {"type": "string"},
    "description": {"type": "string"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+$"},
    "status": {"type": "string", "enum": ["draft", "review", "current", "superseded", "archived"]},
    "source_file": {"type": ["string", "null"]},
    "author": {"type": "string"},
    "last_modified": {"type": "string"},
    "last_modified_by": {"type": "string"},
    "dimensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string"},
          "description": {"type": "string"},
          "values": {"type": "array", "items": {"type": "string"}},
          "required_at_resolution": {"type": "boolean", "default": true}
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "action_fields": {
      "type": "array",
      "description": "Defines the action fields that each rule produces",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {"type": "string"},
          "type": {"type": "string", "enum": ["string", "number", "boolean", "string_array", "object"]},
          "description": {"type": "string"},
          "required": {"type": "boolean", "default": true}
        },
        "additionalProperties": false
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "conditions", "action"],
        "properties": {
          "id": {"type": "string"},
          "conditions": {
            "type": "object",
            "description": "Dimension name → value mapping. Use '*' for wildcard (matches any value).",
            "additionalProperties": {
              "type": ["string", "array", "null"],
              "items": {"type": "string"}
            }
          },
          "action": {
            "type": "object",
            "description": "Action field name → value mapping",
            "additionalProperties": true
          },
          "notes": {"type": "string"},
          "regulatory_ref": {"type": "string"},
          "effective_date": {"type": "string"},
          "expiry_date": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "default_action": {
      "type": "object",
      "description": "Fallback action when no rules match",
      "additionalProperties": true
    },
    "precedence": {
      "type": "string",
      "enum": ["first_match", "most_specific", "all_matching"],
      "default": "first_match",
      "description": "How to resolve when multiple rules match: first_match (first wins), most_specific (most conditions wins), all_matching (merge all)"
    }
  }
}
